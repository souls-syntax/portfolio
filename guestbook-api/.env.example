# These are automatically injected by Vercel when you link a KV (Redis) store.
# You do NOT need to set these manually on Vercel — just link the KV store
# in the Vercel dashboard under Storage > KV.

KV_REST_API_URL=https://your-kv-url.upstash.io
KV_REST_API_TOKEN=your_token_here
KV_REST_API_READ_ONLY_TOKEN=your_readonly_token_here
